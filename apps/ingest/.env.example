# Port the SSE/control server listens on.
PORT=4000
# The web app's public origin, for CORS on the SSE stream + control API.
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
# Where downloaded session recordings are stored.
DATA_DIR=data/recordings
LOG_LEVEL=info
# F1TV auth, required for live mode only — F1 closed unauthenticated access
# to the live timing feed in 2026 (player/replay mode doesn't need any of this).
#
# F1_USERNAME/F1_PASSWORD log in programmatically, but this gets blocked by
# Akamai bot detection from most cloud hosts (see feed/auth.ts). If that
# happens, set F1_SUBSCRIPTION_TOKEN instead: log into F1TV in a real browser,
# pull the resulting subscription token, and paste it here. It's a JWT valid
# for about a week and must be refreshed manually when it expires.
F1_USERNAME=
F1_PASSWORD=
F1_SUBSCRIPTION_TOKEN=
# URL of the apps/f1-sidecar relay (e.g. ws://localhost:8001 locally,
# ws://f1-sidecar.railway.internal:8001 on Railway). When set, live mode
# connects through the sidecar instead of F1 directly — this is what
# actually gets CarData.z/Position.z (see apps/f1-sidecar's README).
# Falls back to the direct connection above if unset.
F1_SIDECAR_URL=
# Optional. A separate cookie (not the subscription token) that a real
# browser sends alongside its login — copy it from DevTools the same way as
# F1_SUBSCRIPTION_TOKEN (Application/Storage > Cookies > entitlement_token on
# formula1.com). Short-lived like the subscription token; refresh manually.
# A leading candidate for what actually gates CarData/Position.
F1_ENTITLEMENT_TOKEN=
# Optional supplementary feed for CarData/Position, which F1's own feed above
# doesn't grant on this account — see feed/openf1/auth.ts. Requires a paid
# openf1.org account (real-time access). Live mode works fine without these,
# just without CarData/Position data.
OPENF1_USERNAME=
OPENF1_PASSWORD=
# Shared secret that must match INGEST_SHARED_SECRET on the web app. If set,
# every request except /api/health must carry it as x-internal-token — this
# is what stops ingest's public URL from bypassing the web app's login gate.
INGEST_SHARED_SECRET=
# LaunchDarkly server-side SDK key. Optional — the server runs fine without
# it, flags just aren't evaluable. Settings > Environments in the LaunchDarkly
# dashboard.
LAUNCHDARKLY_SDK_KEY=
# New Relic APM. Optional — the server runs fine without it, just unmonitored.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=f1-pitwall-ingest
