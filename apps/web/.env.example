# Ingest service URL. REST calls are proxied via /api/ingest (server-side, no CORS).
# The SSE stream still connects from the browser directly, so in production this
# must be a public https URL reachable by clients.
#
# INGEST_URL — server-only; used by the /api/ingest proxy (set on Vercel).
# NEXT_PUBLIC_INGEST_URL — baked into the client bundle for EventSource /api/sse.
# Changing either requires a redeploy.
INGEST_URL=http://localhost:4000
NEXT_PUBLIC_INGEST_URL=http://localhost:4000
