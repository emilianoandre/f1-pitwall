# Ingest service URL — server-only, used by the /api/ingest proxy (REST calls
# and the SSE stream both go through it now, so nothing ingest-related is
# exposed to the browser directly).
#
# INGEST_URL — server-only; falls back to NEXT_PUBLIC_INGEST_URL if unset.
# NEXT_PUBLIC_INGEST_URL — kept as a fallback; no longer used by client code.
INGEST_URL=http://localhost:4000
NEXT_PUBLIC_INGEST_URL=http://localhost:4000

# Login gate. Leave all three unset to run without a login (e.g. local dev).
# Set all three to require a login — see src/middleware.ts.
APP_USERNAME=
APP_PASSWORD=
# Signs the session cookie. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Shared secret the /api/ingest proxy sends to the ingest service so ingest
# can tell proxied requests apart from anyone hitting its public URL directly.
# Must match INGEST_SHARED_SECRET on the ingest service.
INGEST_SHARED_SECRET=

# LaunchDarkly client-side ID (not a secret — ends up in the browser bundle).
# Settings > Environments in the LaunchDarkly dashboard.
NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_SIDE_ID=

# New Relic APM. Optional — the app runs fine without it, just unmonitored.
# Doesn't cover src/middleware.ts (Edge runtime — the Node agent can't
# instrument it), only App Router pages/route handlers.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=f1-pitwall-web
