# URL of the ingest service the browser connects to for the live/replay SSE
# stream and player control. Must be reachable from the user's browser (i.e. a
# public URL in production, not localhost). NEXT_PUBLIC_* is inlined into the
# client bundle at BUILD time — changing it requires a rebuild/redeploy.
NEXT_PUBLIC_INGEST_URL=http://localhost:4000
