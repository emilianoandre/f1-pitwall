# Port the relay WebSocket server listens on (see server.py). apps/ingest's
# F1_SIDECAR_URL should point at ws://<host>:<this port>.
PORT=8001
LOG_LEVEL=info

# F1TV auth, required for the upstream F1 connection — same tradeoffs as
# apps/ingest's own F1_USERNAME/F1_PASSWORD/F1_SUBSCRIPTION_TOKEN (see
# apps/ingest/.env.example): programmatic login often gets blocked by Akamai
# bot detection from cloud hosts, in which case set F1_SUBSCRIPTION_TOKEN
# instead (a manually-captured JWT, valid for about a week). Not fatal if
# unset — the sidecar just fails to authenticate once a client connects.
F1_USERNAME=
F1_PASSWORD=
F1_SUBSCRIPTION_TOKEN=
F1_ENTITLEMENT_TOKEN=

# New Relic custom metrics (see metrics.py for why this uses the Metric API
# directly rather than the full agent). Optional — the sidecar runs fine
# without it, just unmonitored. NEW_RELIC_APP_NAME is a metric attribute
# here, not a registered APM application name.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=f1-pitwall-sidecar
# Metric API is region-specific — override for EU accounts:
# https://metric-api.eu.newrelic.com/metric/v1
NEW_RELIC_METRIC_API_URL=https://metric-api.newrelic.com/metric/v1
